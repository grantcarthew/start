#!/usr/bin/env bash
# Manual CLI testing script
# Prints each command, copies it to the clipboard, then waits for Enter.
# Progress is saved so you can resume where you left off.
# Run from the repository root: ./scripts/manual-test
#
# Options:
#   --reset    Clear saved progress and start from the beginning

CYAN='\033[0;36m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

PROGRESS_FILE="$(dirname "$0")/manual-test-progress"
step=0
completed=0
total=$(grep -c '^cmd "' "$0")

# Parse arguments
for arg in "$@"; do
    case $arg in
        --reset)
            rm -f "$PROGRESS_FILE"
            echo "Progress cleared."
            ;;
        *)
            echo "Unknown option: $arg"
            echo "Usage: $0 [--reset]"
            exit 1
            ;;
    esac
done

# Load saved progress
if [[ -f "$PROGRESS_FILE" ]]; then
    completed=$(wc -l < "$PROGRESS_FILE")
fi

cmd() {
    local section="$1"
    local description="$2"
    local command="$3"

    local key="$section|$description"
    step=$((step + 1))

    # Skip already-completed steps
    if grep -qFx "$key" "$PROGRESS_FILE" 2>/dev/null; then
        return
    fi

    echo
    echo -e "${BOLD}[$step/$total] $section — $description${NC}"
    echo -e "  ${YELLOW}$command${NC}"
    echo -n "$command" | xclip -selection clipboard
    echo -e "  ${CYAN}(copied to clipboard) Press Enter to continue...${NC}"
    read -r

    # Save progress after each step
    echo "$key" >> "$PROGRESS_FILE"
    completed=$((completed + 1))
}

section() {
    echo
    echo -e "${BOLD}========================================"
    echo -e "  $1"
    echo -e "========================================${NC}"
}

# Ensure binary exists
if [[ ! -f "./start" ]]; then
    echo "Building start binary..."
    go build -o ./start ./cmd/start || exit 1
fi

echo -e "${BOLD}Manual CLI Test Script${NC}"
if [[ $completed -gt 0 ]]; then
    echo -e "${GREEN}Resuming${NC} (completed: $completed/$total)"
    echo -e "${DIM}Run with --reset to start from the beginning.${NC}"
else
    echo "Each command is printed and copied to clipboard."
    echo "Run it in another terminal, then press Enter here to advance."
    echo -e "${DIM}Progress is saved automatically — re-run to resume.${NC}"
fi

# --------------------------------------------------------------------------
section "1. Help & Version"
# --------------------------------------------------------------------------

cmd "help" "--help" \
    "./start --help"

cmd "help" "--version" \
    "./start --version"

cmd "help" "prompt --help" \
    "./start prompt --help"

cmd "help" "task --help" \
    "./start task --help"

cmd "help" "config --help" \
    "./start config --help"

cmd "help" "config list --help" \
    "./start config list --help"

cmd "help" "config info --help" \
    "./start config info --help"

cmd "help" "config add --help" \
    "./start config add --help"

cmd "help" "config edit --help" \
    "./start config edit --help"

cmd "help" "config remove --help" \
    "./start config remove --help"

cmd "help" "config search --help" \
    "./start config search --help"

cmd "help" "config open --help" \
    "./start config open --help"

cmd "help" "config order --help" \
    "./start config order --help"

cmd "help" "config export --help" \
    "./start config export --help"

cmd "help" "config settings --help" \
    "./start config settings --help"

cmd "help" "show --help" \
    "./start show --help"

cmd "help" "assets --help" \
    "./start assets --help"

cmd "help" "doctor --help" \
    "./start doctor --help"

cmd "help" "completion --help" \
    "./start completion --help"

